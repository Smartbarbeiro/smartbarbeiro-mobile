# Laravel API base URL (no trailing slash)
# Local: http://127.0.0.1:8000
# ngrok: https://your-subdomain.ngrok-free.dev
# Android emulator: http://10.0.2.2:8000
# Device on LAN: http://192.168.x.x:8000
VITE_API_URL=http://127.0.0.1:8000

# Optional: Web Client ID from Google Cloud (falls back to /api/v1/auth/google/config)
# VITE_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Required for Google Sign-In on iPhone (iOS OAuth client ID from Google Cloud)
# VITE_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
