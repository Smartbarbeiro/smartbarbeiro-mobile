<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Dev: allow HTTP to local Laravel/Vite on LAN (IP changes with Wi‑Fi) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
